{
  "name": "poster-kadai-print-layout-generator",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "backend": "uvicorn backend.main:app --reload --port 8000",
    "dev:desktop": "concurrently \"npm run dev\" \"cross-env NODE_ENV=development electron .\"",
    "build:desktop": "next build && electron-builder",
    "package:win": "next build && electron-builder --win",
    "package:mac": "next build && electron-builder --mac dmg",
    "tauri:setup": "node scripts/setup_tauri.js",
    "tauri:dev": "tauri dev",
    "tauri:build": "next build && tauri build",
    "tauri:android": "tauri android dev",
    "tauri:android-build": "next build && tauri android build --apk",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "~2.0.0",
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "konva": "^9.3.20",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.0.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "~2.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.posterkadai.app",
    "productName": "PosterKadai",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "backend/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "electron/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "electron/icon.png"
    }
  }
}
